# Firebase Configurations
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Twilio Voice Configurations (For Real Calling to non-registered phone numbers)
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
EXPO_PUBLIC_TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# LiveKit Configurations (For actual WebRTC free local in-app calls and live streaming)
EXPO_PUBLIC_LIVEKIT_URL=wss://your-livekit-server-url-here.livekit.cloud
EXPO_PUBLIC_LIVEKIT_API_KEY=your_livekit_api_key_here
EXPO_PUBLIC_LIVEKIT_API_SECRET=your_livekit_api_secret_here
